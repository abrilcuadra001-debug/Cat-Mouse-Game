import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.io.*;
import java.util.ArrayList;
import java.util.Random;
import javax.sound.sampled.*;

public class CatMouseGame extends JFrame implements KeyListener, MouseListener {

    enum CatSkin {
        ORANGE, BLACK, GRAY, WHITE
    }

    private final int WIDTH = 800;
    private final int HEIGHT = 700;

    private final int HUD_HEIGHT = 140;
    private final int MAZE_TOP = HUD_HEIGHT + 20;

    private boolean inStartMenu = true;
    private boolean gameOver = false;

    // Cat
    private int catX = 30;
    private int catY = MAZE_TOP + 25;
    private final int CAT_SIZE = 35;
    private final int CAT_SPEED = 6;
    private CatSkin currentSkin = CatSkin.ORANGE;

    // Hold-to-move flags
    private boolean moveUp = false;
    private boolean moveDown = false;
    private boolean moveLeft = false;
    private boolean moveRight = false;

    // Mouse
    private int mouseX = 650;
    private int mouseY = MAZE_TOP + 250;
    private final int MOUSE_SIZE = 25;
    private int mouseDX = 4;
    private int mouseDY = 4;

    // Cheese
    private int cheeseX = 300;
    private int cheeseY = MAZE_TOP + 200;
    private final int CHEESE_SIZE = 18;

    // Timing
    private Timer timer;
    private long lastSecondTime;
    private int timeLeft = 30;
    private int roundNumber = 1;

    // Scores
    private int totalScore = 0;
    private int totalMiceCaught = 0;
    private int totalCheeseCollected = 0;

    private int roundScore = 0;
    private int roundMiceCaught = 0;
    private int roundCheeseCollected = 0;

    private final int POINTS_PER_MOUSE = 5;
    private final int POINTS_PER_CHEESE = 3;

    // Unlocks
    private final int BLACK_UNLOCK_SCORE = 100;
    private final int GRAY_UNLOCK_SCORE = 300;
    private final int WHITE_UNLOCK_SCORE = 500;

    // Save
    private final String SAVE_FILE = "saveData.txt";

    // Sound
    private float volume = 0.8f;
    private boolean muted = false;

    // Maze
    private final ArrayList<Rectangle> walls = new ArrayList<>();
    private final Random rand = new Random();

    private final GamePanel gamePanel = new GamePanel();

    public CatMouseGame() {
        super("Cat Mouse Game");

        createWalls();
        loadProgress();

        setContentPane(gamePanel);
        gamePanel.setPreferredSize(new Dimension(WIDTH, HEIGHT));
        gamePanel.setBackground(Color.WHITE);

        addKeyListener(this);
        addMouseListener(this);
        gamePanel.addMouseListener(this);

        setFocusable(true);
        setFocusTraversalKeysEnabled(false);

        timer = new Timer(30, e -> {
            if (!inStartMenu && !gameOver) {
                updateCatMovement();
                moveMouse();
                checkCatch();
                checkCheesePickup();
                updateTimer();
            }
            gamePanel.repaint();
        });

        pack();
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null);
        setResizable(false);
        setVisible(true);

        timer.start();

        SwingUtilities.invokeLater(() -> {
            toFront();
            requestFocus();
        });
    }

    private class GamePanel extends JPanel {
        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);

            if (inStartMenu) {
                drawStartMenu(g);
                return;
            }

            g.setColor(Color.BLACK);
            g.setFont(new Font("Arial", Font.BOLD, 22));
            g.drawString("Cat Chases Mouse", 280, 30);

            g.setFont(new Font("Arial", Font.PLAIN, 16));
            g.drawString("Round: " + roundNumber, 30, 55);
            g.drawString("Round Score: " + roundScore, 140, 55);
            g.drawString("Round Mice: " + roundMiceCaught, 300, 55);
            g.drawString("Time Left: " + timeLeft, 460, 55);
            g.drawString("Total Score: " + totalScore, 610, 55);

            g.drawString("Total Mice: " + totalMiceCaught, 30, 80);
            g.drawString("Total Cheese: " + totalCheeseCollected, 170, 80);
            g.drawString("Skin: " + currentSkin, 360, 80);
            g.drawString("Volume: " + getVolumeText(), 560, 80);

            g.drawString("1 Orange", 30, 105);
            g.drawString("2 Black: " + getSkinStatus(CatSkin.BLACK, BLACK_UNLOCK_SCORE), 130, 105);
            g.drawString("3 Gray: " + getSkinStatus(CatSkin.GRAY, GRAY_UNLOCK_SCORE), 340, 105);
            g.drawString("4 White: " + getSkinStatus(CatSkin.WHITE, WHITE_UNLOCK_SCORE), 530, 105);

            g.drawString("Hold WASD to Move   R Next Round   M Mute   +/- Volume", 145, 128);

            g.setColor(new Color(90, 60, 35));
            for (Rectangle wall : walls) {
                g.fillRect(wall.x, wall.y, wall.width, wall.height);
            }

            drawCheese(g);
            drawCat(g);
            drawMouse(g);

            if (gameOver) {
                drawGameOverOverlay(g);
            }
        }
    }

    private void drawGameOverOverlay(Graphics g) {
        Graphics2D g2 = (Graphics2D) g.create();

        g2.setColor(new Color(0, 0, 0, 170));
        g2.fillRect(0, 0, WIDTH, HEIGHT);

        int boxW = 380;
        int boxH = 220;
        int boxX = (WIDTH - boxW) / 2;
        int boxY = (HEIGHT - boxH) / 2;

        g2.setColor(new Color(245, 245, 245));
        g2.fillRoundRect(boxX, boxY, boxW, boxH, 30, 30);

        g2.setColor(Color.DARK_GRAY);
        g2.setStroke(new BasicStroke(3f));
        g2.drawRoundRect(boxX, boxY, boxW, boxH, 30, 30);

        g2.setColor(Color.BLACK);
        g2.setFont(new Font("Arial", Font.BOLD, 34));
        g2.drawString("Round Over!", boxX + 85, boxY + 50);

        g2.setFont(new Font("Arial", Font.PLAIN, 22));
        g2.drawString("Round Score: " + roundScore, boxX + 90, boxY + 95);
        g2.drawString("Mice Caught: " + roundMiceCaught, boxX + 90, boxY + 125);
        g2.drawString("Total Score: " + totalScore, boxX + 90, boxY + 155);

        g2.setFont(new Font("Arial", Font.BOLD, 20));
        g2.drawString("Press R for next round", boxX + 90, boxY + 190);

        g2.dispose();
    }

    private void createWalls() {
        walls.clear();

        int t = 20;
        int top = MAZE_TOP;

        walls.add(new Rectangle(0, top, WIDTH, t));
        walls.add(new Rectangle(0, HEIGHT - t, WIDTH, t));
        walls.add(new Rectangle(0, top, t, HEIGHT - top));
        walls.add(new Rectangle(WIDTH - t, top, t, HEIGHT - top));

        walls.add(new Rectangle(80, top + 40, 220, t));
        walls.add(new Rectangle(380, top + 40, 280, t));
        walls.add(new Rectangle(140, top + 140, 300, t));
        walls.add(new Rectangle(520, top + 140, 180, t));
        walls.add(new Rectangle(80, top + 240, 180, t));
        walls.add(new Rectangle(340, top + 240, 300, t));
        walls.add(new Rectangle(180, top + 340, 260, t));
        walls.add(new Rectangle(520, top + 340, 180, t));

        walls.add(new Rectangle(80, top + 40, t, 140));
        walls.add(new Rectangle(300, top + 40, t, 140));
        walls.add(new Rectangle(440, top + 140, t, 120));
        walls.add(new Rectangle(700, top + 40, t, 120));
        walls.add(new Rectangle(140, top + 140, t, 120));
        walls.add(new Rectangle(260, top + 240, t, 120));
        walls.add(new Rectangle(640, top + 140, t, 120));
        walls.add(new Rectangle(80, top + 240, t, 140));
        walls.add(new Rectangle(440, top + 340, t, 120));
        walls.add(new Rectangle(700, top + 340, t, 120));
        walls.add(new Rectangle(300, top + 340, t, 120));
        walls.add(new Rectangle(660, top + 440, t, 60));
    }

    private void startNewRound(boolean firstRound) {
        catX = 30;
        catY = MAZE_TOP + 25;

        roundScore = 0;
        roundMiceCaught = 0;
        roundCheeseCollected = 0;

        timeLeft = 30;
        gameOver = false;
        clearMovement();
        lastSecondTime = System.currentTimeMillis();

        respawnMouse();
        respawnCheese();

        if (!firstRound) {
            roundNumber++;
        }
    }

    private void clearMovement() {
        moveUp = false;
        moveDown = false;
        moveLeft = false;
        moveRight = false;
    }

    private void updateCatMovement() {
        int dx = 0;
        int dy = 0;

        if (moveLeft) dx -= CAT_SPEED;
        if (moveRight) dx += CAT_SPEED;
        if (moveUp) dy -= CAT_SPEED;
        if (moveDown) dy += CAT_SPEED;

        if (dx != 0 || dy != 0) {
            moveCat(dx, dy);
        }
    }

    private void moveCat(int dx, int dy) {
        if (inStartMenu || gameOver) return;

        int nextX = catX + dx;
        if (nextX < 20) nextX = 20;
        if (nextX > WIDTH - CAT_SIZE - 20) nextX = WIDTH - CAT_SIZE - 20;

        Rectangle nextCatX = new Rectangle(nextX, catY, CAT_SIZE, CAT_SIZE);
        if (!collidesWithWall(nextCatX)) {
            catX = nextX;
        }

        int nextY = catY + dy;
        if (nextY < MAZE_TOP + 20) nextY = MAZE_TOP + 20;
        if (nextY > HEIGHT - CAT_SIZE - 20) nextY = HEIGHT - CAT_SIZE - 20;

        Rectangle nextCatY = new Rectangle(catX, nextY, CAT_SIZE, CAT_SIZE);
        if (!collidesWithWall(nextCatY)) {
            catY = nextY;
        }
    }

    private boolean collidesWithWall(Rectangle r) {
        for (Rectangle wall : walls) {
            if (r.intersects(wall)) return true;
        }
        return false;
    }

    private void moveMouse() {
        int nextX = mouseX + mouseDX;
        int nextY = mouseY + mouseDY;

        Rectangle nextMouseX = new Rectangle(nextX, mouseY, MOUSE_SIZE, MOUSE_SIZE);
        Rectangle nextMouseY = new Rectangle(mouseX, nextY, MOUSE_SIZE, MOUSE_SIZE);

        boolean hitX = false;
        boolean hitY = false;

        for (Rectangle wall : walls) {
            if (nextMouseX.intersects(wall)) hitX = true;
            if (nextMouseY.intersects(wall)) hitY = true;
        }

        if (hitX) mouseDX *= -1;
        else mouseX += mouseDX;

        if (hitY) mouseDY *= -1;
        else mouseY += mouseDY;
    }

    private void checkCatch() {
        Rectangle cat = new Rectangle(catX, catY, CAT_SIZE, CAT_SIZE);
        Rectangle mouse = new Rectangle(mouseX, mouseY, MOUSE_SIZE, MOUSE_SIZE);

        if (cat.intersects(mouse)) {
            roundMiceCaught++;
            totalMiceCaught++;
            roundScore += POINTS_PER_MOUSE;
            totalScore += POINTS_PER_MOUSE;

            playSound("sounds/meow.wav");
            playSound("sounds/squeak.wav");

            saveProgress();
            respawnMouse();
        }
    }

    private void checkCheesePickup() {
        Rectangle cat = new Rectangle(catX, catY, CAT_SIZE, CAT_SIZE);
        Rectangle cheese = new Rectangle(cheeseX, cheeseY, CHEESE_SIZE, CHEESE_SIZE);

        if (cat.intersects(cheese)) {
            roundCheeseCollected++;
            totalCheeseCollected++;
            roundScore += POINTS_PER_CHEESE;
            totalScore += POINTS_PER_CHEESE;

            playSound("sounds/cheese.wav");

            saveProgress();
            respawnCheese();
        }
    }

    private void respawnMouse() {
        boolean valid = false;

        while (!valid) {
            mouseX = 40 + rand.nextInt(WIDTH - 100 - MOUSE_SIZE);
            mouseY = MAZE_TOP + 20 + rand.nextInt(HEIGHT - MAZE_TOP - 100 - MOUSE_SIZE);

            Rectangle mouse = new Rectangle(mouseX, mouseY, MOUSE_SIZE, MOUSE_SIZE);
            Rectangle cat = new Rectangle(catX, catY, CAT_SIZE, CAT_SIZE);

            valid = !collidesWithWall(mouse) && !mouse.intersects(cat);
        }
    }

    private void respawnCheese() {
        boolean valid = false;

        while (!valid) {
            cheeseX = 40 + rand.nextInt(WIDTH - 100 - CHEESE_SIZE);
            cheeseY = MAZE_TOP + 20 + rand.nextInt(HEIGHT - MAZE_TOP - 100 - CHEESE_SIZE);

            Rectangle cheese = new Rectangle(cheeseX, cheeseY, CHEESE_SIZE, CHEESE_SIZE);
            Rectangle cat = new Rectangle(catX, catY, CAT_SIZE, CAT_SIZE);
            Rectangle mouse = new Rectangle(mouseX, mouseY, MOUSE_SIZE, MOUSE_SIZE);

            valid = !collidesWithWall(cheese) && !cheese.intersects(cat) && !cheese.intersects(mouse);
        }
    }

    private void updateTimer() {
        long currentTime = System.currentTimeMillis();
        if (currentTime - lastSecondTime >= 1000) {
            timeLeft--;
            lastSecondTime = currentTime;

            if (timeLeft <= 0) {
                gameOver = true;
                clearMovement();
                saveProgress();
            }
        }
    }

    private boolean isSkinUnlocked(CatSkin skin) {
        switch (skin) {
            case ORANGE: return true;
            case BLACK: return totalScore >= BLACK_UNLOCK_SCORE;
            case GRAY: return totalScore >= GRAY_UNLOCK_SCORE;
            case WHITE: return totalScore >= WHITE_UNLOCK_SCORE;
            default: return false;
        }
    }

    private String getSkinStatus(CatSkin skin, int unlockScore) {
        return isSkinUnlocked(skin) ? "Unlocked" : "Locked (" + unlockScore + ")";
    }

    private void saveProgress() {
        try (PrintWriter writer = new PrintWriter(new FileWriter(SAVE_FILE))) {
            writer.println(totalScore);
            writer.println(totalMiceCaught);
            writer.println(totalCheeseCollected);
            writer.println(currentSkin.name());
            writer.println(volume);
            writer.println(muted);
        } catch (IOException e) {
            System.out.println("Could not save progress.");
        }
    }

    private void loadProgress() {
        File file = new File(SAVE_FILE);
        if (!file.exists()) return;

        try (BufferedReader reader = new BufferedReader(new FileReader(file))) {
            totalScore = Integer.parseInt(reader.readLine());
            totalMiceCaught = Integer.parseInt(reader.readLine());
            totalCheeseCollected = Integer.parseInt(reader.readLine());

            String savedSkin = reader.readLine();
            String savedVolume = reader.readLine();
            String savedMuted = reader.readLine();

            if (savedSkin != null) {
                try {
                    CatSkin loadedSkin = CatSkin.valueOf(savedSkin);
                    currentSkin = isSkinUnlocked(loadedSkin) ? loadedSkin : CatSkin.ORANGE;
                } catch (IllegalArgumentException e) {
                    currentSkin = CatSkin.ORANGE;
                }
            }

            if (savedVolume != null) {
                volume = Float.parseFloat(savedVolume);
                if (volume < 0.0f) volume = 0.0f;
                if (volume > 1.0f) volume = 1.0f;
            }

            if (savedMuted != null) {
                muted = Boolean.parseBoolean(savedMuted);
            }

        } catch (Exception e) {
            totalScore = 0;
            totalMiceCaught = 0;
            totalCheeseCollected = 0;
            currentSkin = CatSkin.ORANGE;
            volume = 0.8f;
            muted = false;
        }
    }

    private void playSound(String fileName) {
        if (muted) return;

        try {
            AudioInputStream audio = AudioSystem.getAudioInputStream(new File(fileName));
            Clip clip = AudioSystem.getClip();
            clip.open(audio);

            if (clip.isControlSupported(FloatControl.Type.MASTER_GAIN)) {
                FloatControl gainControl = (FloatControl) clip.getControl(FloatControl.Type.MASTER_GAIN);
                float min = gainControl.getMinimum();
                float max = gainControl.getMaximum();
                float gain = (volume <= 0.0f) ? min : min + (max - min) * volume;
                gainControl.setValue(gain);
            }

            clip.start();
        } catch (Exception e) {
            System.out.println("Sound error: " + fileName);
        }
    }

    private void increaseVolume() {
        volume += 0.1f;
        if (volume > 1.0f) volume = 1.0f;
        saveProgress();
    }

    private void decreaseVolume() {
        volume -= 0.1f;
        if (volume < 0.0f) volume = 0.0f;
        saveProgress();
    }

    private String getVolumeText() {
        return muted ? "Muted" : (int) (volume * 100) + "%";
    }

    private void drawCat(Graphics g) {
        switch (currentSkin) {
            case ORANGE: g.setColor(Color.ORANGE); break;
            case BLACK: g.setColor(Color.BLACK); break;
            case GRAY: g.setColor(Color.GRAY); break;
            case WHITE: g.setColor(Color.WHITE); break;
        }

        g.fillOval(catX, catY, CAT_SIZE, CAT_SIZE);
        g.setColor(Color.BLACK);
        g.drawOval(catX, catY, CAT_SIZE, CAT_SIZE);
    }

    private void drawMouse(Graphics g) {
        g.setColor(Color.GRAY);
        g.fillOval(mouseX, mouseY, MOUSE_SIZE, MOUSE_SIZE);
        g.setColor(Color.BLACK);
        g.drawOval(mouseX, mouseY, MOUSE_SIZE, MOUSE_SIZE);
    }

    private void drawCheese(Graphics g) {
        g.setColor(Color.YELLOW);
        g.fillOval(cheeseX, cheeseY, CHEESE_SIZE, CHEESE_SIZE);
        g.setColor(Color.ORANGE);
        g.drawOval(cheeseX, cheeseY, CHEESE_SIZE, CHEESE_SIZE);
    }

    private void drawStartMenu(Graphics g) {
        g.setColor(Color.WHITE);
        g.fillRect(0, 0, WIDTH, HEIGHT);

        g.setColor(Color.BLACK);
        g.setFont(new Font("Arial", Font.BOLD, 40));
        g.drawString("Cat Chases Mouse", 220, 140);

        g.setFont(new Font("Arial", Font.PLAIN, 24));
        g.drawString("Press ENTER to Start", 275, 200);

        g.setFont(new Font("Arial", Font.PLAIN, 18));
        g.drawString("Hold WASD = Move", 300, 290);
        g.drawString("Saved Total Score: " + totalScore, 290, 350);
    }

    @Override
    public void keyPressed(KeyEvent e) {
        int k = e.getKeyCode();

        if (inStartMenu && k == KeyEvent.VK_ENTER) {
            startNewRound(true);
            inStartMenu = false;
            repaint();
            return;
        }

        if (k == KeyEvent.VK_W) moveUp = true;
        if (k == KeyEvent.VK_S) moveDown = true;
        if (k == KeyEvent.VK_A) moveLeft = true;
        if (k == KeyEvent.VK_D) moveRight = true;

        if (gameOver && k == KeyEvent.VK_R) {
            startNewRound(false);
        }

        if (k == KeyEvent.VK_1) currentSkin = CatSkin.ORANGE;
        if (k == KeyEvent.VK_2 && isSkinUnlocked(CatSkin.BLACK)) currentSkin = CatSkin.BLACK;
        if (k == KeyEvent.VK_3 && isSkinUnlocked(CatSkin.GRAY)) currentSkin = CatSkin.GRAY;
        if (k == KeyEvent.VK_4 && isSkinUnlocked(CatSkin.WHITE)) currentSkin = CatSkin.WHITE;

        if (k == KeyEvent.VK_M) muted = !muted;
        if (k == KeyEvent.VK_EQUALS) increaseVolume();
        if (k == KeyEvent.VK_MINUS) decreaseVolume();

        repaint();
    }

    @Override
    public void keyReleased(KeyEvent e) {
        int k = e.getKeyCode();

        if (k == KeyEvent.VK_W) moveUp = false;
        if (k == KeyEvent.VK_S) moveDown = false;
        if (k == KeyEvent.VK_A) moveLeft = false;
        if (k == KeyEvent.VK_D) moveRight = false;
    }

    @Override
    public void keyTyped(KeyEvent e) {
    }

    @Override
    public void mouseClicked(MouseEvent e) {
        requestFocus();
    }

    @Override
    public void mousePressed(MouseEvent e) {
        requestFocus();
    }

    @Override
    public void mouseReleased(MouseEvent e) {
    }

    @Override
    public void mouseEntered(MouseEvent e) {
    }

    @Override
    public void mouseExited(MouseEvent e) {
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> {
            CatMouseGame game = new CatMouseGame();
            game.toFront();
            game.requestFocus();
        });
    }
}
